class InetAddressHook(MethodHook):
    def __init__(self, plugin):
        super().__init__()
        self.plugin = plugin

    def before_hooked_method(self, param):
        try:
            if not self.plugin.get_setting("enable_firewall", False):
                return
            host = param.args[0]
            if host is None:
                return
            if not self.plugin.is_host_whitelisted(str(host)):
                param.setThrowable(jclass("java.net.UnknownHostException")("Host blocked by AyuPlus Firewall"))
        except Exception:
            pass

class SocketConnectHook(MethodHook):
    def __init__(self, plugin):
        super().__init__()
        self.plugin = plugin

    def before_hooked_method(self, param):
        try:
            if not self.plugin.get_setting("enable_firewall", False):
                return
            endpoint = param.args[0]
            if endpoint is None:
                return
            address = endpoint.getAddress()
            if address is not None:
                ip = str(address.getHostAddress())
                host = str(address.getHostName())
                if not self.plugin.is_host_whitelisted(ip) and not self.plugin.is_host_whitelisted(host):
                    param.setThrowable(jclass("java.io.IOException")("Connection blocked by AyuPlus Firewall"))
        except Exception:
            pass

class AyuPlusPlugin(BasePlugin):
    def on_plugin_load(self):
        self.queues = {}
        self.processing = {}
        self.last_scheduled_time = {}
        self.ghost_chats_cache = {}
        self.ghost_linked_chats_cache = {}
        self.ghost_leaving_channels = {}
        self.queue_lock = threading.Lock()
        self.add_on_send_message_hook()
        try:
            ActionBarLayout = jclass("org.telegram.ui.ActionBar.ActionBarLayout")
            self.hook_all_methods(ActionBarLayout, "presentFragment", PresentFragmentHook(self))
        except Exception:
            pass
        try:
            MessagesController = jclass("org.telegram.messenger.MessagesController")
            self.hook_all_methods(MessagesController, "getChat", GetChatHook(self))
        except Exception:
            pass
        try:
            MessagesController = jclass("org.telegram.messenger.MessagesController")
            self.hook_all_methods(MessagesController, "getChatFull", GetChatFullHook(self))
        except Exception:
            pass
        try:
            DownloadController = jclass("org.telegram.messenger.DownloadController")
            self.hook_all_methods(DownloadController, "canDownloadMedia", DownloadControllerHook(self))
        except Exception:
            pass
        try:
            FileLoader = jclass("org.telegram.messenger.FileLoader")
            self.hook_all_methods(FileLoader, "loadFile", FileLoaderHook(self))
        except Exception:
            pass
        try:
            AnimatedEmojiSpan = jclass("org.telegram.ui.Components.AnimatedEmojiSpan")
            self.hook_all_methods(AnimatedEmojiSpan, "<init>", AnimatedEmojiSpanHook(self))
        except Exception:
            pass
        try:
            MessageObject = jclass("org.telegram.messenger.MessageObject")
            self.hook_all_methods(MessageObject, "<init>", MessageObjectHook(self))
        except Exception:
            pass
        try:
            ChatMessageCell = jclass("org.telegram.ui.Cells.ChatMessageCell")
            self.hook_all_methods(ChatMessageCell, "setMessageObject", ChatMessageCellHook(self))
        except Exception:
            pass
        try:
            InetAddress = jclass("java.net.InetAddress")
            self.hook_all_methods(InetAddress, "getAllByName", InetAddressHook(self))
            self.hook_all_methods(InetAddress, "getByName", InetAddressHook(self))
        except Exception:
            pass
        try:
            Socket = jclass("java.net.Socket")
            self.hook_all_methods(Socket, "connect", SocketConnectHook(self))
        except Exception:
            pass
        
        self.add_hook("TL_channels_joinChannel")
        self.add_hook("TL_channels_leaveChannel")
        self.add_hook("TL_messages_setTyping")
        self.add_hook("TL_messages_saveDraft")
        self.add_hook("saveDraft", match_substring=True)
        self.add_hook("TL_messages_getInlineBotResults")
        self.add_hook("getInlineBotResults", match_substring=True)
        self.add_hook("TL_messages_getBotCallbackAnswer")
        self.add_hook("getBotCallbackAnswer", match_substring=True)
        self.add_hook("TL_messages_sendMessage")
        self.add_hook("TL_messages_editMessage")
        self.add_hook("TL_messages_sendMedia")
        self.add_hook("TL_messages_sendMultiMedia")
        self.add_hook("TL_messages_forwardMessages")
        self.add_hook("TL_messages_sendInlineBotResult")
        
        self.add_hook("getWebPage", match_substring=True)
        
        run_on_ui_thread(self.initialize_restoration, 3000)

    def initialize_restoration(self):
        self.restore_all_ghost_dialogs()
        for account in range(4):
            try:
                UserConfig = jclass("org.telegram.messenger.UserConfig")
                user_config = UserConfig.getInstance(account)
                if user_config.isClientActivated():
                    self.load_queue_from_disk(account)
            except Exception:
                pass

    def on_plugin_unload(self):
        pass

