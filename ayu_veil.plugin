RequestDelegate = jclass("org.telegram.tgnet.RequestDelegate")

def get_data_path():
    try:
        app_context = jclass("org.telegram.messenger.ApplicationLoader").applicationContext
        base_dir = str(app_context.getExternalFilesDir(None).getAbsolutePath())
    except Exception:
        base_dir = "/storage/emulated/0/Android/data/org.telegram.messenger/files"
    target_dir = os.path.join(base_dir, "AyuPlus")
    if not os.path.exists(target_dir):
        try:
            os.makedirs(target_dir)
        except Exception:
            pass
    return os.path.join(target_dir, "data.json")

def load_saved_data():
    path = get_data_path()
    if os.path.exists(path):
        try:
            with open(path, "r") as f:
                return json.loads(f.read())
        except Exception:
            pass
    return {}

def save_data_to_file(data):
    path = get_data_path()
    try:
        with open(path, "w") as f:
            f.write(json.dumps(data))
    except Exception:
        pass

class PresentFragmentHook(MethodHook):
    def __init__(self, plugin):
        super().__init__()
        self.plugin = plugin

    def before_hooked_method(self, param):
        try:
            if not self.plugin.get_setting("enable_queue", True):
                return
            fragment = param.args[0]
            if fragment is None:
                return
            class_name = fragment.getClass().getName()
            if "ScheduledMessagesActivity" in class_name:
                is_auto_open = False
                for element in Thread.currentThread().getStackTrace():
                    m_name = element.getMethodName()
                    c_name = element.getClassName()
                    if "didReceivedNotification" in m_name or "NotificationCenter" in c_name:
                        is_auto_open = True
                        break
                if is_auto_open:
                    param.setResult(False)
        except Exception:
            pass

class GetChatHook(MethodHook):
    def __init__(self, plugin):
        super().__init__()
        self.plugin = plugin

    def after_hooked_method(self, param):
        try:
            if not self.plugin.get_setting("ghost_join", True):
                return
            chat = param.getResult()
            if chat is not None:
                account = getattr(param.thisObject, "currentAccount", 0)
                chat_id = chat.id
                if hasattr(chat_id, "longValue"):
                    chat_id = chat_id.longValue()
                chat_id = int(chat_id)
                if self.plugin.should_spoof_chat(account, chat_id):
                    chat.left = False
                    chat.kicked = False
        except Exception:
            pass

class GetChatFullHook(MethodHook):
    def __init__(self, plugin):
        super().__init__()
        self.plugin = plugin

    def after_hooked_method(self, param):
        try:
            if not self.plugin.get_setting("ghost_join", True):
                return
            chat_full = param.getResult()
            if chat_full is not None:
                linked_chat_id = getattr(chat_full, "linked_chat_id", 0)
                if linked_chat_id:
                    account = getattr(param.thisObject, "currentAccount", 0)
                    args = param.args
                    if args and len(args) > 0:
                        chat_id = args[0]
                        if hasattr(chat_id, "longValue"):
                            chat_id = chat_id.longValue()
                        chat_id = int(chat_id)
                        if self.plugin.is_ghost_joined(account, chat_id):
                            if hasattr(linked_chat_id, "longValue"):
                                linked_chat_id = linked_chat_id.longValue()
                            linked_chat_id = int(linked_chat_id)
                            self.plugin.add_ghost_linked_chat(account, chat_id, linked_chat_id)
        except Exception:
            pass

class AnalysisRequestDelegate(dynamic_proxy(RequestDelegate)):
    def __init__(self, plugin, account, peer, invite_hash):
        super().__init__()
        self.plugin = plugin
        self.account = account
        self.peer = peer
        self.invite_hash = invite_hash

    def run(self, response, error):
        try:
            if error is not None:
                err_text = getattr(error, "text", "Unknown Error")
                self.plugin.send_analysis_report(self.account, self.peer, f"Error inspecting link: {err_text}")
                return
            if response is not None:
                self.plugin.process_analysis_response(self.account, self.peer, self.invite_hash, response)
        except Exception:
            pass

class FileLoaderHook(MethodHook):
    def __init__(self, plugin):
        super().__init__()
        self.plugin = plugin

    def before_hooked_method(self, param):
        try:
            if not self.plugin.get_setting("anti_exploit", True):
                return
            args = param.args
            if not args or len(args) < 1:
                return

            parent = None
            for arg in args:
                if arg is None:
                    continue
                try:
                    cls_name = arg.getClass().getSimpleName()
                    if "MessageObject" in cls_name or "TL_message" in cls_name or "Message" in cls_name:
                        parent = arg
                        break
                except Exception:
                    pass

            if parent is None and len(args) >= 2:
                if len(args) >= 10:
                    parent = args[5]
                else:
                    parent = args[1]

            if parent is None:
                param.setResult(None)
                return

            cls_name = parent.getClass().getSimpleName()
            message = None
            if "MessageObject" in cls_name:
                message = getattr(parent, "messageOwner", None)
            elif "TL_message" in cls_name or "Message" in cls_name:
                message = parent

            if message is None:
                param.setResult(None)
                return

            out = getattr(message, "out", False)
            if not out:
                param.setResult(None)
        except Exception:
            pass

class DownloadControllerHook(MethodHook):
    def __init__(self, plugin):
        super().__init__()
        self.plugin = plugin

    def after_hooked_method(self, param):
        try:
            if not self.plugin.get_setting("anti_exploit", True):
                return
            args = param.args
            if not args or len(args) < 1:
                return
            message_object = args[0]
            if message_object is None:
                return
            message = getattr(message_object, "messageOwner", None)
            if message is None:
                return

            out = getattr(message, "out", False)
            if not out:
                param.setResult(False)
        except Exception:
            pass

class AnimatedEmojiSpanHook(MethodHook):
    def __init__(self, plugin):
        super().__init__()
        self.plugin = plugin

    def before_hooked_method(self, param):
        try:
            if not self.plugin.get_setting("anti_exploit", True):
                return
            args = param.args
            if args and len(args) > 0:
                first_arg = args[0]
                if first_arg is not None:
                    cls_name = first_arg.getClass().getSimpleName()
                    if "Long" in cls_name or "Integer" in cls_name or isinstance(first_arg, int):
                        param.args[0] = 0
                    else:
                        param.args[0] = None
        except Exception:
            pass

class MessageObjectHook(MethodHook):
    def __init__(self, plugin):
        super().__init__()
        self.plugin = plugin

    def after_hooked_method(self, param):
        try:
            if not self.plugin.get_setting("anti_exploit", True):
                return
            message_object = param.thisObject
            if message_object is None:
                return
            message = getattr(message_object, "messageOwner", None)
            if message is None:
                return

            out = getattr(message, "out", False)
            if not out:
                try:
                    message.media = jclass("org.telegram.tgnet.TLRPC$TL_messageMediaEmpty")()
                except Exception:
                    try:
                        TLRPC = jclass("org.telegram.tgnet.TLRPC")
                        message.media = TLRPC.TL_messageMediaEmpty()
                    except Exception:
                        pass

                reply_markup = getattr(message, "reply_markup", None)
                if reply_markup is not None:
                    rows = getattr(reply_markup, "rows", None)
                    if rows is not None:
                        rows.clear()

                entities = getattr(message, "entities", None)
                if entities is not None:
                    entities.clear()
        except Exception:
            pass

